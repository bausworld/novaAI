# Nova AI - Environment Variables
# Copy this to .env.local and fill in your keys

# OpenAI API Key (optional - runs in demo mode without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# YouTube Data API v3 Key (optional - uses mock data without it)
YOUTUBE_API_KEY=

# Brave Search API Key (optional - uses mock data without it)
BRAVE_SEARCH_API_KEY=
